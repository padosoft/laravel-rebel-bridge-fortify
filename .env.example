# ============================================================================
# laravel-rebel-bridge-fortify — environment variables
# All optional: they have sensible defaults in config/rebel-bridge-fortify.php.
# ============================================================================

# Which Fortify-backed step-up drivers to register into the Rebel step-up registry.
# password_confirm works without Fortify; totp needs Fortify; passkey needs a
# PasskeyConfirmer implementation bound in your app.
REBEL_FORTIFY_DRIVER_PASSWORD=true
REBEL_FORTIFY_DRIVER_TOTP=true
REBEL_FORTIFY_DRIVER_PASSKEY=true

# Map framework auth events (login/failed/logout/lockout) and Fortify two-factor
# lifecycle events into the Rebel audit trail (rebel_auth_events).
REBEL_FORTIFY_AUDIT_EVENTS=true
